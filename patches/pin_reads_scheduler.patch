diff --git a/packages/opencode/src/tool/pin.ts b/packages/opencode/src/tool/pin.ts
new file mode 100644
index 000000000..946f74fb9
--- /dev/null
+++ b/packages/opencode/src/tool/pin.ts
@@ -0,0 +1,49 @@
+import { z } from "zod"
+import { Tool } from "./tool"
+import { Session } from "../session"
+import { Filesystem } from "../util/filesystem"
+
+export const PinReadsTool = Tool.define("pin-reads", {
+  description: "Pin a list of files to the context for continuous monitoring. Use an empty array to unpin all files.",
+  parameters: z.object({
+    paths: z.array(z.string()).describe("Absolute paths of files to pin."),
+  }),
+  execute: async (args, ctx) => {
+    const session = await Session.get(ctx.sessionID)
+    const metadata = session.metadata ?? {}
+    const pinnedFiles = (metadata.pinnedFiles as Record<string, any>) ?? {}
+
+    if (args.paths.length === 0) {
+      delete metadata.pinnedFiles
+      await Session.updateMetadata({ sessionID: ctx.sessionID, metadata })
+      return {
+        title: "Pin Reads",
+        metadata: { pinnedCount: 0 },
+        output: "All files unpinned.",
+      }
+    }
+
+    const results: string[] = []
+    for (const path of args.paths) {
+      if (!(await Filesystem.exists(path))) {
+        results.push(`Error: File ${path} does not exist.`)
+        continue
+      }
+      
+      pinnedFiles[path] = {
+        path,
+        score: 100, // 初始分數
+        lastSeenTurn: ctx.messages.length,
+      }
+      results.push(`Pinned: ${path}`)
+    }
+
+    metadata.pinnedFiles = pinnedFiles
+    await Session.updateMetadata({ sessionID: ctx.sessionID, metadata })
+    return {
+      title: "Pin Reads",
+      metadata: { pinnedCount: results.length },
+      output: results.join("\n"),
+    }
+  },
+})
